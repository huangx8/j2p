# JIRA — server URL only (for building PR description links)
# Authentication is handled by Claude Code's built-in JIRA MCP integration.
JIRA_SERVER=https://enterprise-anz.atlassian.net

# GitHub — authenticated via local `gh` CLI (run `gh auth login` to set up)
# Run `which gh` to find the path. Leave as `gh` if it's on your PATH.
GH_CLI_PATH=gh
GITHUB_BASE_BRANCH=main
# Default GitHub org prepended to bare repo names found in JIRA tickets or entered manually.
# E.g. set to "myorg" so "myrepo" is treated as "myorg/myrepo".
# Leave blank if your repos always include the org in the JIRA description.
GITHUB_DEFAULT_ORG=

# Claude Code CLI
# Path to the locally installed `claude` binary.
# Run `which claude` to find it. Leave as `claude` if it's on your PATH.
CLAUDE_CLI_PATH=claude

# Agent Configuration
WORKSPACE_DIR=/tmp/j2p_workspace
PR_POLL_INTERVAL_SECONDS=60
MAX_REVIEW_ITERATIONS=10

